<Window x:Class="LED_DDP_DRIVER.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LED_DDP_DRIVER.UI"
        Title="LED DDP Audio Controller" Height="620" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <UniformGrid Columns="2">
                <TextBlock Text="Config connection:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" VerticalAlignment="Bottom"/>
                <GroupBox Header="Out Monitor (Telemetry)" Padding="10" Margin="0,0,0,15" FontWeight="Bold">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Center">
                            <TextBlock Text="MASTER" TextAlignment="Center" Margin="0,0,0,5" Foreground="Gray" FontWeight="Normal"/>
                            <Border Width="80" Height="32" CornerRadius="5" Background="{Binding MasterColorBrush}" 
        BorderBrush="#444" BorderThickness="2">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="5" Opacity="0.3" ShadowDepth="2"/>
                                </Border.Effect>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="R:" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding CurrentR}" Maximum="255" Height="15" Foreground="Red" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentR}" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="G:" Foreground="Green" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding CurrentG}" Maximum="255" Height="15" Foreground="Green" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentG}" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="35"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="B:" Foreground="Blue" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding CurrentB}" Maximum="255" Height="15" Foreground="DodgerBlue" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentB}" TextAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </GroupBox>
            </UniformGrid>
            
            
            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="IP Address:"/>
                    <TextBox x:Name="ipAddr_TextBox" Text="{Binding IpAddress}" Padding="3"/>
                </StackPanel>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Port:"/>
                    <TextBox x:Name="port_TextBox" Text="{Binding Port}" Padding="3"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="System Logs:" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkBlue"/>
                <TextBox x:Name="TxtInfoConsole" Grid.Row="1" 
                         Text="{Binding InfoLogs, Mode=OneWay}" 
                         behaviors:TextBoxBehavior.AutoScrollToEnd="True"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F5F5F5" Padding="5" Margin="0,0,0,60"/>
                <Button x:Name="run_Button" Content="RUN" Command="{Binding RunDDPServiceCommand}" HorizontalAlignment="Left" Margin="10,305,0,0" Grid.Row="1" VerticalAlignment="Bottom" Height="44" Width="62"/>
                <Button x:Name="stop_Button" Content="STOP" Command="{Binding StopDDPServiceCommand}" HorizontalAlignment="Left" Margin="77,305,0,0" Grid.Row="1" VerticalAlignment="Bottom" Height="44" Width="62"/>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="DDP Data Stream:" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkGreen"/>
                <TextBox x:Name="TxtDdpConsole" Grid.Row="1" 
                         Text="{Binding DdpLogs, Mode=OneWay}" 
                         behaviors:TextBoxBehavior.AutoScrollToEnd="True"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F0FBF0" Padding="5" Margin="0,0,0,60"/>
            </Grid>
        </Grid>
    </Grid>
</Window>