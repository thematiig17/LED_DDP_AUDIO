<Window x:Class="LED_DDP_DRIVER.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LED_DDP_DRIVER.UI"
        Title="LED DDP Audio Controller" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Konfiguracja połączenia:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Adres IP:"/>
                    <TextBox x:Name="ipAddr_TextBox" Text="{Binding IpAddress}" Padding="3"/>
                </StackPanel>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Port:"/>
                    <TextBox x:Name="port_TextBox" Text="{Binding Port}" Padding="3"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Logi Systemowe (INFO):" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkBlue"/>
                <TextBox x:Name="TxtInfoConsole" Grid.Row="1" 
                         Text="{Binding InfoLogs, Mode=OneWay}" 
                         behaviors:TextBoxBehavior.AutoScrollToEnd="True"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F5F5F5" Padding="5" Margin="0,0,0,60"/>
                <Button x:Name="run_Button" Content="RUN" HorizontalAlignment="Left" Margin="10,305,0,0" Grid.Row="1" VerticalAlignment="Top" Height="44" Width="62"/>
                <Button x:Name="stop_Button" Content="STOP" HorizontalAlignment="Left" Margin="77,305,0,0" Grid.Row="1" VerticalAlignment="Top" Height="44" Width="62"/>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Strumień danych DDP:" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkGreen"/>
                <TextBox x:Name="TxtDdpConsole" Grid.Row="1" 
                         Text="{Binding DdpLogs, Mode=OneWay}" 
                         behaviors:TextBoxBehavior.AutoScrollToEnd="True"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F0FBF0" Padding="5" Margin="0,0,0,60"/>
            </Grid>
        </Grid>
    </Grid>
</Window>