<Window x:Class="LED_DDP_DRIVER.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LED_DDP_DRIVER.UI"
        Title="LED DDP Audio Controller" Height="620" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,0">
            <UniformGrid Columns="2">
                <GroupBox Header="Pre-Processing" Padding="10" Margin="0,0,0,00" FontWeight="Bold">
                    <StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="GAIN" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="THRESHOLD" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="7" Text="DECAY" Foreground="Gray" FontSize="10" HorizontalAlignment="Center"/>

                            <CheckBox Grid.Row="1" Grid.Column="0" Content="BASS" Foreground="Red" FontWeight="Bold" 
          IsChecked="{Binding AudioSettings.IsBassEnabled}" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="20" Value="{Binding AudioSettings.BassGain}" Margin="5,0"/>
                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding AudioSettings.BassGain, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" TextAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="4" Minimum="0" Maximum="1" Value="{Binding AudioSettings.BassThreshold}" Margin="2,0"/>
                            <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding AudioSettings.BassThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" TextAlignment="Center"/>
                            <Slider Grid.Row="1" Grid.Column="7" Minimum="0" Maximum="0.99" Value="{Binding AudioSettings.BassDecay}" Margin="2,0"/>
                            <TextBox Grid.Row="1" Grid.Column="8" Text="{Binding AudioSettings.BassDecay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" TextAlignment="Center"/>

                            <CheckBox Grid.Row="2" Grid.Column="0" Content="MID" Foreground="Green" FontWeight="Bold" 
          IsChecked="{Binding AudioSettings.IsMidEnabled}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="20" Value="{Binding AudioSettings.MidGain}" Margin="5,10,5,0"/>
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding AudioSettings.MidGain, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" TextAlignment="Center" Margin="0,10,0,0"/>
                            <Slider Grid.Row="2" Grid.Column="4" Minimum="0" Maximum="1" Value="{Binding AudioSettings.MidThreshold}" Margin="2,10,2,0"/>
                            <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding AudioSettings.MidThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" TextAlignment="Center" Margin="0,10,0,0"/>
                            <Slider Grid.Row="2" Grid.Column="7" Minimum="0" Maximum="0.99" Value="{Binding AudioSettings.MidDecay}" Margin="2,10,2,0"/>
                            <TextBox Grid.Row="2" Grid.Column="8" Text="{Binding AudioSettings.MidDecay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" TextAlignment="Center" Margin="0,10,0,0"/>

                            <CheckBox Grid.Row="3" Grid.Column="0" Content="HIGH" Foreground="DodgerBlue" FontWeight="Bold" 
          IsChecked="{Binding AudioSettings.IsHighEnabled}" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="20" Value="{Binding AudioSettings.HighGain}" Margin="5,10,5,0"/>
                            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding AudioSettings.HighGain, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F1}}" TextAlignment="Center" Margin="0,10,0,0"/>
                            <Slider Grid.Row="3" Grid.Column="4" Minimum="0" Maximum="1" Value="{Binding AudioSettings.HighThreshold}" Margin="2,10,2,0"/>
                            <TextBox Grid.Row="3" Grid.Column="5" Text="{Binding AudioSettings.HighThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" TextAlignment="Center" Margin="0,10,0,0"/>
                            <Slider Grid.Row="3" Grid.Column="7" Minimum="0" Maximum="0.99" Value="{Binding AudioSettings.HighDecay}" Margin="2,10,2,0"/>
                            <TextBox Grid.Row="3" Grid.Column="8" Text="{Binding AudioSettings.HighDecay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" TextAlignment="Center" Margin="0,10,0,0"/>
                        </Grid>

                        <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,15,0,5" Padding="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="MASTER BRIGHTNESS:" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.01" Value="{Binding AudioSettings.MasterBrightness}" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding AudioSettings.MasterBrightness, StringFormat={}{0:P0}}" TextAlignment="Right" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </GroupBox>
                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <GroupBox Header="Out Monitor (Telemetry)" Padding="10" FontWeight="Bold" Height="120">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="18*"/>
                                <ColumnDefinition Width="211*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Center">
                                <TextBlock Text="MASTER" TextAlignment="Center" Margin="0,0,0,5" Foreground="Gray" FontWeight="Normal"/>
                                <Border Width="80" Height="52" CornerRadius="5" Background="{Binding MasterColorBrush}" 
        BorderBrush="#444" BorderThickness="2">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="5" Opacity="0.3" ShadowDepth="2"/>
                                    </Border.Effect>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Column="1" VerticalAlignment="Center" Grid.ColumnSpan="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="R:" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding CurrentR}" Maximum="255" Height="15" Foreground="Red" Background="#E0E0E0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentR}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="G:" Foreground="Green" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding CurrentG}" Maximum="255" Height="15" Foreground="Green" Background="#E0E0E0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentG}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="B:" Foreground="Blue" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding CurrentB}" Maximum="255" Height="15" Foreground="DodgerBlue" Background="#E0E0E0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentB}" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Visualization Algorithm" Padding="10" FontWeight="Bold" Height="70">
                        <ComboBox ItemsSource="{Binding AvailableModes}" 
              SelectedItem="{Binding SelectedMode}" 
              DisplayMemberPath="Name"
              Padding="8,5"
              FontWeight="Normal"
              Cursor="Hand">

                            <ComboBox.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="3" Opacity="0.1" ShadowDepth="1"/>
                            </ComboBox.Effect>

                        </ComboBox>
                    </GroupBox>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Config connection:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" VerticalAlignment="Bottom"/>
            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="IP Address:"/>
                    <TextBox x:Name="ipAddr_TextBox" Text="{Binding IpAddress}" Padding="3"/>
                </StackPanel>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="Port:"/>
                    <TextBox x:Name="port_TextBox" Text="{Binding Port}" Padding="3"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="System Logs:" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkBlue"/>
                <TextBox x:Name="TxtInfoConsole" Grid.Row="1" 
                         Text="{Binding InfoLogs, Mode=OneWay}" 
                         behaviors:TextBoxBehavior.AutoScrollToEnd="True"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F5F5F5" Padding="5" Margin="0,0,0,60"/>
                <Button x:Name="run_Button" Content="RUN" Command="{Binding RunDDPServiceCommand}" HorizontalAlignment="Left" Margin="10,10,0,0" Grid.Row="1" VerticalAlignment="Bottom" Height="44" Width="62"/>
                <Button x:Name="stop_Button" Content="STOP" Command="{Binding StopDDPServiceCommand}" HorizontalAlignment="Left" Margin="77,10,0,0" Grid.Row="1" VerticalAlignment="Bottom" Height="44" Width="62"/>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="DDP Data Stream:" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkGreen"/>
                <TextBox x:Name="TxtDdpConsole" Grid.Row="1" 
                         Text="{Binding DdpLogs, Mode=OneWay}" 
                         behaviors:TextBoxBehavior.AutoScrollToEnd="True"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F0FBF0" Padding="5" Margin="0,0,0,60"/>
            </Grid>
        </Grid>
    </Grid>
</Window>